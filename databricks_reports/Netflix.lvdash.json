    },
    {
      "name": "6cc147ef",
      "displayName": "Engagement Breakdown by Cohort",
      "queryLines": [
        "SELECT\n",
        "  source_label,\n",
        "  'Seen' as response_type,\n",
        "  seen_count as count\n",
        "FROM\n",
        "  netflix.`03_gold`.gold_elicitation_source_summary\n",
        "UNION ALL\n",
        "SELECT\n",
        "  source_label,\n",
        "  'Not Seen' as response_type,\n",
        "  not_seen_count as count\n",
        "FROM\n",
        "  netflix.`03_gold`.gold_elicitation_source_summary\n",
        "UNION ALL\n",
        "SELECT\n",
        "  source_label,\n",
        "  'No Response' as response_type,\n",
        "  no_response_count as count\n",
        "FROM\n",
        "  netflix.`03_gold`.gold_elicitation_source_summary"
      ]
    }
  ],
